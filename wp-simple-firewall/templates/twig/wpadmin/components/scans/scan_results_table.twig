{% set panel_status = table.status %}
{% set full_log_button_class = table.full_log_button_class %}
{% set table_notice = table.display_notice %}

{% set table_markup %}
	<div class="alert alert-{{ table_notice.status|e('html_attr') }} mb-2{% if not table_notice.is_visible %} d-none{% endif %}"
		 data-scan-results-display-notice="1"
		 data-scan-results-display-notice-mode="{{ table_notice.mode|e('html_attr') }}"
		 data-scan-results-display-notice-ignored-count="{{ table_notice.ignored_count|e('html_attr') }}">
		{{ table_notice.text }}
	</div>
	<div class="row shield-section-datatable">
		<div class="col">
			{% if table.is_empty %}
				<div class="alert alert-{{ table.empty_status }} mb-0">{{ table.empty_text }}</div>
			{% else %}
				<table id="{{ table.table_id|e('html_attr') }}"
					   class="table table-striped table-bordered"
					   style="width: 100%;"
					   data-scan-results-table="1"
					   data-datatables-init="{{ table.datatables_init_attr|e('html_attr') }}"
					   data-table-action="{{ table.table_action_attr|e('html_attr') }}"
					   data-results-display-options="{{ table.results_display_options_attr|e('html_attr') }}"
					   {% if table.render_item_analysis_attr is not empty %}data-render-item-analysis="{{ table.render_item_analysis_attr|e('html_attr') }}"{% endif %}
				></table>
			{% endif %}
		</div>
	</div>
{% endset %}

{% if table.is_flat %}
	<section class="investigate-table-panel investigate-table-panel--flat mb-3 status-{{ panel_status }}">
		{% if table.show_header %}
			<div class="d-flex justify-content-between align-items-center mb-3">
				<h5 class="card-title mb-0">{{ table.title }}</h5>
				{% if table.full_log_href is not empty %}
					<a href="{{ table.full_log_href }}" class="{{ full_log_button_class }}">{{ table.full_log_text }}</a>
				{% endif %}
			</div>
		{% endif %}
		{{ table_markup }}
	</section>
{% else %}
	<section class="card shield-card mb-3 status-{{ panel_status }}">
		<div class="shield-card-accent status-{{ panel_status }}"></div>
		<div class="card-body">
			{% if table.show_header %}
				<div class="d-flex justify-content-between align-items-center mb-3">
					<h5 class="card-title mb-0">{{ table.title }}</h5>
					{% if table.full_log_href is not empty %}
						<a href="{{ table.full_log_href }}" class="{{ full_log_button_class }}">{{ table.full_log_text }}</a>
					{% endif %}
				</div>
			{% endif %}
			{{ table_markup }}
		</div>
	</section>
{% endif %}
